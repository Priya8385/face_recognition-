from sklearn.neighbors import KNeighborsClassifier
import cv2
import pickle
import numpy as np
import os
import csv
import time
import subprocess
from datetime import datetime


def speak(text: str) -> None:
    try:
        subprocess.run(["espeak", text], check=False)
    except FileNotFoundError:
        print("espeak is not installed. Run: sudo apt install espeak -y")


def main() -> None:
    os.makedirs("Attendance", exist_ok=True)

    video = cv2.VideoCapture(0)
    if not video.isOpened():
        print("Error: Could not open camera.")
        return

    cascade_path = "data/haarcascade_frontalface_default.xml"
    if not os.path.isfile(cascade_path):
        print(f"Error: Cascade file not found: {cascade_path}")
        video.release()
        return

    facedetect = cv2.CascadeClassifier(cascade_path)
    if facedetect.empty():
        print("Error: Failed to load Haar cascade.")
        video.release()
        return

    names_path = "data/names.pkl"
    faces_path = "data/faces_data.pkl"

    if not os.path.isfile(names_path):
        print(f"Error: File not found: {names_path}")
        video.release()
        return

    if not os.path.isfile(faces_path):
        print(f"Error: File not found: {faces_path}")
        video.release()
        return

    with open(names_path, "rb") as w:
        labels = pickle.load(w)

    with open(faces_path, "rb") as f:
        faces = pickle.load(f)

    faces = np.asarray(faces)
    labels = np.asarray(labels)

    if len(faces) == 0 or len(labels) == 0:
        print("Error: Training data is empty.")
        video.release()
        return

    if len(faces) != len(labels):
        print("Error: Number of faces and labels do not match.")
        video.release()
        return

    print("Shape of Faces matrix -->", faces.shape)

    knn = KNeighborsClassifier(n_neighbors=5)
    knn.fit(faces, labels)

    img_background = cv2.imread("background.png")
    use_background = img_background is not None

    col_names = ["NAME", "TIME"]
    last_attendance = None
    last_date = None

    while True:
        ret, frame = video.read()
        if not ret:
            print("Error: Failed to read frame from camera.")
            break

        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        detected_faces = facedetect.detectMultiScale(gray, scaleFactor=1.3, minNeighbors=5)

        display_frame = frame.copy()

        for (x, y, w, h) in detected_faces:
            crop_img = frame[y:y + h, x:x + w, :]
            resized_img = cv2.resize(crop_img, (50, 50)).flatten().reshape(1, -1)
            output = knn.predict(resized_img)

            ts = time.time()
            date = datetime.fromtimestamp(ts).strftime("%d-%m-%Y")
            timestamp = datetime.fromtimestamp(ts).strftime("%H:%M-%S")

            cv2.rectangle(display_frame, (x, y), (x + w, y + h), (50, 50, 255), 2)
            cv2.rectangle(display_frame, (x, y - 40), (x + w, y), (50, 50, 255), -1)
            cv2.putText(
                display_frame,
                str(output[0]),
                (x, y - 15),
                cv2.FONT_HERSHEY_COMPLEX,
                1,
                (255, 255, 255),
                1
            )

            last_attendance = [str(output[0]), str(timestamp)]
            last_date = date

        if use_background and img_background.shape[0] >= 162 + 480 and img_background.shape[1] >= 55 + 640:
            bg = img_background.copy()
            bg[162:162 + 480, 55:55 + 640] = cv2.resize(display_frame, (640, 480))
            cv2.imshow("Frame", bg)
        else:
            cv2.imshow("Frame", display_frame)

        k = cv2.waitKey(1) & 0xFF

        if k == ord("o"):
            if last_attendance is None or last_date is None:
                print("No face detected. Attendance not taken.")
                speak("No face detected")
                continue

            speak("Attendance Taken")

            file_path = os.path.join("Attendance", f"Attendance_{last_date}.csv")
            file_exists = os.path.isfile(file_path)

            with open(file_path, "a", newline="") as csvfile:
                writer = csv.writer(csvfile)
                if not file_exists:
                    writer.writerow(col_names)
                writer.writerow(last_attendance)

            print("Attendance saved:", last_attendance)

        if k == ord("q"):
            break

    video.release()
    cv2.destroyAllWindows()


if __name__ == "__main__":
    main()
